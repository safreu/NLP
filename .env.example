# Copy this file to .env and fill in the values. .env is gitignored.
#
# Hugging Face access token used ONLY to download license-gated open-weights
# models such as Gemma. Accept the model license on the model's Hub page first,
# then create a read token at https://huggingface.co/settings/tokens.
#
# This token is used for the download only and is never written to any output
# file (predictions or scores). No hosted-inference API is used.
HF_TOKEN=hf_your_read_token_here
